{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "teammateMode": "in-process"
  },
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Bash(python execution/**/*.py)",
      "Bash(py execution/**/*.py)",
      "Bash(python3 execution/**/*.py)",
      "Bash(python execution/generate_registry.py)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Read(C:\\Users\\deban\\dev\\anneal\\**)",
      "Read(C:\\Users\\deban\\dev\\humanizer\\**)",
      "Read(C:\\Users\\deban\\dev\\youtube-video-analyzer\\**)",
      "Read(C:\\Users\\deban\\dev\\cv-optimizer-agent\\**)",
      "Read(C:\\Users\\deban\\dev\\mobile-apps\\**)",
      "Edit(C:\\Users\\deban\\dev\\anneal\\**)",
      "Edit(C:\\Users\\deban\\dev\\humanizer\\**)",
      "Edit(C:\\Users\\deban\\dev\\youtube-video-analyzer\\**)",
      "Write(C:\\Users\\deban\\dev\\anneal\\**)",
      "Write(C:\\Users\\deban\\dev\\humanizer\\**)",
      "Write(C:\\Users\\deban\\dev\\youtube-video-analyzer\\**)",
      "Glob(C:\\Users\\deban\\dev\\**)",
      "Grep(C:\\Users\\deban\\dev\\**)",
      "Bash(ls C:\\Users\\deban\\dev\\**)",
      "Bash(dir C:\\Users\\deban\\dev\\**)",
      "Bash(git -C C:\\Users\\deban\\dev\\humanizer\\* *)",
      "Bash(cd C:\\Users\\deban\\dev\\humanizer\\* && *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/safety-guard.sh\""
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/notify-done.sh\" Alarm01.wav",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/notify-done.sh\" Alarm01.wav",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/note-taker.sh\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/format-python.sh\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/documenter-prompt.sh\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/session-start.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/notify-done.sh\" tada.wav",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/notify-done.sh\" Alarm01.wav",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
