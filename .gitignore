# Secrets & credentials — NEVER commit
.env
credentials.json
token.json
*.json.key
credentials/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Workspace temp & archive
.tmp/
.archive/

# OS
.DS_Store
Thumbs.db
*.png
*.msix

# Website assets — these PNGs are intentionally tracked (override *.png above)
!website/assets/*.png

# IDE
.vscode/
.idea/

# Claude worktrees
.claude/worktrees/

# Personal Claude overrides (machine-specific, not shared)
CLAUDE.local.md
.claude/settings.local.json

# Generated output files
output/

# Firecrawl cache
.firecrawl/

# Node / Workers dev dependencies
node_modules/

# Wrangler build artifacts
.wrangler/

# Stray ad-hoc smoke/debug logs (workspace root)
/smoke_*_stdout.txt
/smoke_*_stderr.txt

# JPG screenshots dropped at workspace root (out-of-band)
/[0-9]*.jpg

# anneal transcripts (local audit logs)
.anneal/
