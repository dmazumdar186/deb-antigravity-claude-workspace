{
  "client": "accessory_masters",
  "version": "1.0",
  "icp": {
    "industries": [
      "car wash",
      "pizzeria",
      "laundromat",
      "marina",
      "small oil company",
      "auto repair",
      "dry cleaner",
      "bakery",
      "printing shop",
      "pest control",
      "manufacturing",
      "professional services"
    ],
    "geography": {
      "city": "Houston",
      "state": "TX",
      "include_suburbs": true,
      "suburbs": [
        "Katy",
        "Sugar Land",
        "The Woodlands",
        "Pearland",
        "Pasadena"
      ]
    },
    "employee_range": [5, 50],
    "revenue_range": [1000000, 20000000]
  },
  "sourcing": {
    "serper_results_per_query": 100,
    "serper_api_url": "https://google.serper.dev/maps",
    "prospeo_api_url": "https://api.prospeo.io",
    "use_prospeo_for": [],
    "prospeo_note": "Prospeo V2 API deprecated company-email-finder. Use Serper for all niches. Prospeo available for domain-based contact enrichment."
  },
  "enrichment": {
    "anymailfinder_api_url": "https://api.anymailfinder.com",
    "anymailfinder_min_confidence": 50,
    "million_verifier_api_url": "https://api.millionverifier.com/api/v3",
    "million_verifier_accept": ["ok", "catch_all"],
    "million_verifier_reject": ["invalid", "disposable"]
  },
  "personalization": {
    "model": "anthropic/claude-haiku-4-5-20251001",
    "tone_config": "config/tone.json",
    "max_opener_tokens": 100,
    "batch_size": 50
  },
  "copy_optimization": {
    "enabled": true,
    "model": "anthropic/claude-haiku-4-5-20251001",
    "max_variants": 5,
    "human_variant_count": 4,
    "min_sends_for_comparison": 100,
    "replacement_threshold_pct": 0.5,
    "variants_file": "config/email_variants.json",
    "variant_constraints": {
      "max_words": 60,
      "max_sentences": 3,
      "no_exclamation_marks": true
    }
  },
  "instantly": {
    "api_url": "https://api.instantly.ai/api/v2",
    "campaign_id": null,
    "upload_rate_limit_delay": 1.0,
    "field_mapping": {
      "email": "owner_email",
      "first_name_from": "owner_name",
      "last_name_from": "owner_name",
      "company_name": "business_name",
      "custom_variables": {
        "opener": "personalized_opener",
        "industry": "industry",
        "city": "city"
      }
    }
  },
  "ghl": {
    "api_url": "https://services.leadconnectorhq.com",
    "api_version": "2021-07-28",
    "location_id": "sCxQ92Y8b7PpfLloGqOn",
    "pipeline_id": null,
    "pipeline_stages": {
      "new": null,
      "contacted": null,
      "interested": null,
      "booked": null,
      "closed": null
    },
    "tags": ["cold email", "positive reply"],
    "source": "cold email pipeline"
  },
  "classification": {
    "model": "anthropic/claude-haiku-4-5-20251001",
    "system_prompt": "Classify this cold email reply as exactly one of: hot_positive, positive, negative, neutral.\nhot_positive = prospect gives a phone number, says ready to sell, wants to schedule a call immediately\npositive = interested in selling their business, wants to talk, asks about the process\nnegative = not interested, asks to be removed, hostile, unsubscribe\nneutral = out of office, auto-reply, bounce, unclear intent\nReply with exactly one word: hot_positive, positive, negative, or neutral.",
    "categories": ["hot_positive", "positive", "negative", "neutral"],
    "mock_signals": {
      "hot_positive": ["phone number", "call me at", "my number is", "ready to sell", "want to sell now"],
      "negative": ["not interested", "remove", "stop", "unsubscribe", "no thanks", "don't", "no longer"],
      "neutral": ["out of office", "auto-reply", "vacation", "will return"],
      "positive": ["interested", "sell", "process", "tell me more", "call me", "yes"]
    }
  },
  "auto_reply": {
    "enabled": true,
    "model": "anthropic/claude-haiku-4-5-20251001",
    "delay_min_seconds": 120,
    "delay_max_seconds": 420,
    "delay_increases_with_time_of_day": true,
    "max_sentences": 3,
    "max_words": 60,
    "voice": "I",
    "sender_persona": "Aleksandar, business broker backed by Hedgestone Capital Group",
    "objection_responses": {
      "not_ready": {
        "triggers": ["not ready", "not right now", "maybe later", "not the right time"],
        "response": "Totally understand. Actually, now's a great time to at least get a valuation — the market's moving fast. No pressure, happy to chat whenever."
      },
      "valuation": {
        "triggers": ["how much", "what's it worth", "business worth", "valuation"],
        "response": "Depends on a few things — revenue, industry, location. I can give you a rough range on a quick call. Want to set one up?"
      },
      "who_are_you": {
        "triggers": ["who are you", "who is this", "what company", "never heard of"],
        "response": "I'm Alex with Accessory Masters, backed by Hedgestone Capital Group. We've closed over $100M in deals. Happy to share more on a call."
      }
    },
    "hot_lead_signals": ["phone number", "my number", "call me at", "ready to sell", "want to sell", "schedule a call"],
    "stop_on_hot_lead": true,
    "guard_rails": [
      "Never promise specific valuations",
      "Never use exclamation marks",
      "Never write more than 3 sentences",
      "Never mention AI or automation",
      "Never use sales-y or corporate language"
    ]
  },
  "notifications": {
    "telegram_enabled": true,
    "telegram_bot_token": null,
    "telegram_chat_id": null,
    "slack_enabled": false,
    "slack_template": null,
    "sms_enabled": false
  },
  "reporting": {
    "enabled": true,
    "frequency": "weekly",
    "day_of_week": "monday",
    "recipients": [],
    "telegram_enabled": true,
    "slack_enabled": false,
    "email_enabled": false,
    "smtp_config": null,
    "html_template": null,
    "slack_template": null,
    "telegram_template": null
  },
  "pipeline": {
    "output_dir": ".tmp",
    "state_file": ".tmp/pipeline_state.json",
    "daily_lead_target": 800,
    "reply_poll_interval_minutes": 30
  }
}
