---
const year = new Date().getFullYear();
---
<footer class="container-page py-10 border-t border-ink-900/8">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-sm text-ink-700">
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="ProdCraft logo" width="44" height="44" class="h-11 w-11 object-contain" />
      <span class="font-mono">© {year} ProdCraft · An AI-build studio by Debanjan Mazumdar · Paris</span>
    </div>
    <div class="flex items-center gap-x-5 gap-y-2 flex-wrap font-mono text-xs text-ink-700/80">
      <a href="#services" class="brass-underline hover:text-ink-900">Services</a>
      <a href="#systems" class="brass-underline hover:text-ink-900">Systems</a>
      <a href="#contact" class="brass-underline hover:text-ink-900">Contact</a>
    </div>
  </div>
</footer>
