---
import data from '../content/recommendations.en.json';
---
<section class="container-page py-20 md:py-28">
  <header class="max-w-3xl mb-12">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-brass-500 mb-4" data-reveal>{data.section_eyebrow}</p>
    <h2 class="headline-serif text-3xl md:text-4xl lg:text-5xl leading-[1.05] mb-4" data-reveal>{data.section_title}</h2>
    <p class="text-base md:text-lg text-ink-700 leading-relaxed" data-reveal>{data.section_intro}</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
    {data.quotes.map((q) => (
      <figure class="tile flex flex-col gap-4">
        <blockquote class="font-serif text-xl md:text-2xl leading-snug tracking-tight text-ink-900">
          <span aria-hidden="true" class="text-brass-400 mr-1">"</span>{q.quote}<span aria-hidden="true" class="text-brass-400 ml-1">"</span>
        </blockquote>
        <figcaption class="mt-auto pt-4 border-t border-ink-900/8 flex items-center justify-between">
          <div>
            <div class="font-medium text-ink-900">{q.name}</div>
            <div class="text-sm text-ink-700">{q.role}{q.company && q.company !== '—' ? ` · ${q.company}` : ''}</div>
          </div>
          {q.linkedin_url && q.linkedin_url !== '#' && (
            <a href={q.linkedin_url} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-ink-700 brass-underline">verify ↗</a>
          )}
        </figcaption>
      </figure>
    ))}
  </div>
</section>
