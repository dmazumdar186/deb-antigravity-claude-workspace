---
import data from '../content/hero.en.json';
---
<section id="top" class="container-page pt-16 md:pt-24 pb-16 md:pb-24">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-10 items-center">
    <div class="md:col-span-7 order-2 md:order-1">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-brass-500 mb-6 flex items-center gap-3" data-reveal>
        <span class="text-ink-900 font-semibold">{data.brand}</span>
        <span class="h-px w-6 bg-ink-900/20"></span>
        <span>{data.brand_tagline}</span>
      </p>
      <h1 class="headline-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] mb-8" data-reveal>
        {data.headline}
      </h1>
      <p class="text-lg md:text-xl text-ink-700 max-w-2xl leading-relaxed mb-10" data-reveal>
        {data.subhead}
      </p>
      <div class="flex flex-col sm:flex-row gap-3" data-reveal>
        <a href={data.primary_cta.href} class="btn-primary brass-underline">
          {data.primary_cta.label}
          <span aria-hidden="true">→</span>
        </a>
        <a href={data.secondary_cta.href} class="btn-secondary">
          {data.secondary_cta.label}
        </a>
      </div>
    </div>

    <div class="md:col-span-5 order-1 md:order-2">
      <div class="relative aspect-[4/5] w-full max-w-md mx-auto overflow-hidden rounded-3xl bg-ink-900/5 border border-ink-900/8">
        <picture>
          <source srcset="/headshot.webp" type="image/webp" />
          <img
            src="/headshot.jpg"
            alt={data.headshot_alt}
            data-ken-burns
            width="671"
            height="839"
            loading="eager"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover"
            onerror="this.style.display='none'; this.closest('.relative').querySelector('[data-fallback]').style.display='flex';"
          />
        </picture>
        <div data-fallback class="absolute inset-0 hidden items-center justify-center bg-ink-900 text-bone-100" aria-hidden="true">
          <span class="font-serif text-8xl tracking-tightest text-brass-400">DM</span>
        </div>
        <div class="absolute bottom-4 left-4 right-4">
          <div class="rounded-xl bg-ink-900/70 backdrop-blur-md px-4 py-3 border border-bone-100/10 text-bone-100">
            <div class="font-sans text-sm font-semibold leading-tight">{data.operator_name}</div>
            <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-bone-100/70 mt-1">{data.operator_role} · {data.operator_location}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
