---
import data from '../content/systems.en.json';
---
<section id="systems" class="container-page py-20 md:py-28">
  <header class="max-w-3xl mb-12 md:mb-16">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-brass-500 mb-4" data-reveal>{data.section_eyebrow}</p>
    <h2 class="headline-serif text-4xl md:text-5xl lg:text-6xl leading-[1.05] mb-5" data-reveal>{data.section_title}</h2>
    <p class="text-lg text-ink-700 leading-relaxed" data-reveal>{data.section_intro}</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
    {data.cards.map((card) => (
      <article class="tile tile-hoverable group flex flex-col gap-4 relative overflow-hidden">
        <div class="flex items-center justify-between gap-3">
          <span class="font-mono text-xs uppercase tracking-[0.18em] text-brass-500">{card.category}</span>
          {card.live_url && (
            <a href={card.live_url} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-ink-700 brass-underline">live ↗</a>
          )}
        </div>
        <h3 class="font-serif text-2xl md:text-3xl tracking-tightest text-ink-900 leading-tight">{card.title}</h3>
        <p class="text-ink-700 leading-relaxed">{card.description}</p>

        <div class="grid grid-cols-2 gap-3 mt-2">
          {card.metrics.slice(0, 2).map((m) => (
            <div>
              <div class="font-mono text-2xl md:text-3xl tracking-tightest text-ink-900">{m.value}</div>
              <div class="text-xs text-ink-700 mt-1">{m.label}</div>
            </div>
          ))}
        </div>

        <details class="mt-2 group/details">
          <summary class="cursor-pointer font-mono text-xs text-ink-700 brass-underline list-none">
            <span class="group-open/details:hidden">how it works ↓</span>
            <span class="hidden group-open/details:inline">collapse ↑</span>
          </summary>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">{card.brief}</p>
          {card.metrics.length > 2 && (
            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs font-mono text-ink-700">
              {card.metrics.slice(2).map((m) => (
                <span><span class="text-ink-900">{m.value}</span> {m.label}</span>
              ))}
            </div>
          )}
          {card.embed_iframe && card.live_url && (
            <div class="mt-4 rounded-xl overflow-hidden border border-ink-900/8 bg-bone-100">
              <iframe src={card.live_url} loading="lazy" class="w-full aspect-[4/3]" title={card.title}></iframe>
            </div>
          )}
        </details>
      </article>
    ))}
  </div>
</section>
