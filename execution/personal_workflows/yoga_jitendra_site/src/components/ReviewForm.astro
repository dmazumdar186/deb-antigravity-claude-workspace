---
// ReviewForm.astro — inline review submission form.
//
// Posts to /review-submit (public CF Pages Function, Turnstile-guarded,
// IP rate-limited). Falls back gracefully if PUBLIC_TURNSTILE_SITE_KEY
// is not set — the form is disabled with a friendly notice, so the site
// never renders a broken widget.
//
// Props:
//   lang         'fr' | 'en'
//   compact      boolean   if true, render a smaller variant (used inside
//                          Testimonials section on the homepage; the full
//                          /reviews page uses the non-compact variant)

const { lang = 'fr', compact = false } = Astro.props;

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const enabled = !!siteKey;

const t = {
  fr: {
    heading_full: 'Laissez votre avis',
    heading_compact: 'Vous êtes déjà venu·e ? Laissez votre avis.',
    subheading: 'Chaque avis est modéré avant publication. Merci d\'écrire depuis votre expérience réelle.',
    name: 'Votre prénom',
    name_placeholder: 'Prénom (ou prénom + initiale du nom)',
    rating: 'Note',
    body: 'Votre avis',
    body_placeholder: 'Quelques phrases sur votre expérience avec Jitendra…',
    source: 'Où avez-vous pratiqué ?',
    source_options: {
      onsite: 'Sur le site (nouveau)',
      superprof: 'Superprof',
      meetup: 'Meetup',
      trainme: 'TrainMe',
      instagram: 'Instagram',
      email: 'Recommandation privée',
      other: 'Autre',
    },
    consent: 'J\'accepte que mon prénom et mon avis soient publiés sur ce site.',
    submit: 'Envoyer mon avis',
    disabled_notice: 'Les avis en ligne sont temporairement indisponibles. Contactez Jitendra directement via WhatsApp.',
    wa_cta: 'Contacter par WhatsApp',
    thanks_title: 'Merci !',
    thanks_body: 'Votre avis a bien été reçu. Il sera publié après modération.',
    error_prefix: 'Erreur : ',
    errors: {
      name: 'Prénom requis.',
      rating: 'Note requise (1 à 5).',
      body_short: 'Votre avis est trop court (min. 20 caractères).',
      source: 'Source invalide.',
      lang: 'Langue invalide.',
      consent: 'Vous devez cocher le consentement.',
      turnstile_missing: 'Vérification anti-bot requise.',
      turnstile_failed: 'Vérification anti-bot échouée. Réessayez.',
      turnstile_unconfigured: 'Formulaire non configuré. Réessayez plus tard.',
      rate_limited: 'Vous avez déjà envoyé un avis aujourd\'hui. Merci !',
      kv_unbound: 'Stockage indisponible. Réessayez plus tard.',
      bad_form: 'Formulaire invalide.',
    },
  },
  en: {
    heading_full: 'Leave your review',
    heading_compact: 'Practised with Jitendra? Leave a review.',
    subheading: 'Every review is moderated before publication. Please write from your real experience.',
    name: 'Your first name',
    name_placeholder: 'First name (or first name + last initial)',
    rating: 'Rating',
    body: 'Your review',
    body_placeholder: 'A few lines about your experience with Jitendra…',
    source: 'Where did you practice?',
    source_options: {
      onsite: 'On this site (new)',
      superprof: 'Superprof',
      meetup: 'Meetup',
      trainme: 'TrainMe',
      instagram: 'Instagram',
      email: 'Private recommendation',
      other: 'Other',
    },
    consent: 'I agree that my first name and my review may be published on this site.',
    submit: 'Send my review',
    disabled_notice: 'Online reviews are temporarily unavailable. Reach Jitendra directly on WhatsApp.',
    wa_cta: 'Contact on WhatsApp',
    thanks_title: 'Thank you!',
    thanks_body: 'Your review has been received. It will appear here after moderation.',
    error_prefix: 'Error: ',
    errors: {
      name: 'First name required.',
      rating: 'Rating required (1 to 5).',
      body_short: 'Your review is too short (min. 20 characters).',
      source: 'Invalid source.',
      lang: 'Invalid language.',
      consent: 'Consent checkbox required.',
      turnstile_missing: 'Bot-check required.',
      turnstile_failed: 'Bot-check failed. Try again.',
      turnstile_unconfigured: 'Form not configured. Try again later.',
      rate_limited: 'You already submitted a review today. Thanks!',
      kv_unbound: 'Storage unavailable. Try again later.',
      bad_form: 'Invalid form.',
    },
  },
}[lang === 'en' ? 'en' : 'fr'];

const heading = compact ? t.heading_compact : t.heading_full;
const waHref = `/wa-out?source=contact&text=${encodeURIComponent(lang === 'en' ? 'Hi Jitendra, I would like to share my feedback.' : 'Bonjour Jitendra, je souhaite vous transmettre un retour.')}&utm_source=site&utm_medium=whatsapp&utm_content=review_fallback_${lang}`;
---

<div class="review-form-wrap card" data-review-form data-lang={lang} data-compact={compact ? '1' : '0'}>
  <div class="review-form-header">
    <p class="eyebrow">
      <span class="breathing-dot"></span>
      <span>{heading}</span>
    </p>
    <p class="review-form-sub">{t.subheading}</p>
  </div>

  {!enabled ? (
    <div class="review-form-disabled">
      <p>{t.disabled_notice}</p>
      <a href={waHref} class="btn btn-primary">{t.wa_cta}</a>
    </div>
  ) : (
    <form
      class="review-form"
      method="POST"
      action="/review-submit"
      data-review-submit-form
    >
      {/* Honeypot — real users won't fill this; bots often will. Hidden via CSS. */}
      <div class="review-honeypot" aria-hidden="true">
        <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
      </div>

      <input type="hidden" name="lang" value={lang} />

      <div class="review-field">
        <label for="rf-name">{t.name}</label>
        <input id="rf-name" type="text" name="name" required maxlength="60" minlength="2" placeholder={t.name_placeholder} />
      </div>

      <div class="review-field">
        <label>{t.rating}</label>
        <div class="rating-picker" role="radiogroup" aria-label={t.rating}>
          {[5, 4, 3, 2, 1].map((n) => (
            <label class="rating-star">
              <input type="radio" name="rating" value={n} required aria-label={`${n} / 5`} />
              <span aria-hidden="true">★</span>
              <span class="sr-only">{n} / 5</span>
            </label>
          ))}
        </div>
      </div>

      <div class="review-field">
        <label for="rf-body">{t.body}</label>
        <textarea id="rf-body" name="body" required minlength="20" maxlength="2000" rows={compact ? 4 : 6} placeholder={t.body_placeholder}></textarea>
      </div>

      <div class="review-field">
        <label for="rf-source">{t.source}</label>
        <select id="rf-source" name="source">
          {Object.entries(t.source_options).map(([k, v]) => (
            <option value={k} selected={k === 'onsite'}>{v}</option>
          ))}
        </select>
      </div>

      <div class="review-field review-field-consent">
        <label>
          <input type="checkbox" name="consent" value="on" required />
          <span>{t.consent}</span>
        </label>
      </div>

      <div class="review-turnstile">
        <div
          class="cf-turnstile"
          data-sitekey={siteKey}
          data-action="turnstile-spin-v1"
          data-theme="light"
          data-appearance="interaction-only"
        />
      </div>

      <div class="review-submit-row">
        <button type="submit" class="btn btn-primary">{t.submit}</button>
      </div>

      <div class="review-form-status" data-review-form-status hidden />
    </form>
  )}
</div>

{enabled && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
)}

<style>
  .review-form-wrap {
    background: rgba(255, 254, 251, 0.85);
    max-width: 720px;
    margin-inline: auto;
  }
  .review-form-header { margin-bottom: 1rem; }
  .review-form-sub {
    color: var(--ink-soft, #6b6560);
    font-size: 0.9rem;
    margin: 0.5rem 0 0;
  }
  .review-form { display: flex; flex-direction: column; gap: 1rem; }
  .review-field { display: flex; flex-direction: column; gap: 0.35rem; }
  .review-field label { font-size: 0.85rem; color: var(--ink-soft, #6b6560); font-weight: 500; }
  .review-field input[type="text"],
  .review-field textarea,
  .review-field select {
    font: inherit;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(46, 42, 38, 0.16);
    border-radius: 8px;
    background: white;
    color: var(--ink-900, #2e2a26);
  }
  .review-field textarea { resize: vertical; min-height: 100px; }
  .review-field input:focus,
  .review-field textarea:focus,
  .review-field select:focus {
    outline: none;
    border-color: var(--terracotta, #c05b3e);
    box-shadow: 0 0 0 3px rgba(192, 91, 62, 0.15);
  }

  .rating-picker {
    display: inline-flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 0.15rem;
  }
  .rating-star { cursor: pointer; }
  .rating-star input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .rating-star span[aria-hidden="true"] {
    font-size: 1.75rem;
    color: rgba(46, 42, 38, 0.2);
    transition: color 0.15s ease;
    line-height: 1;
    display: inline-block;
    padding: 0 2px;
  }
  .rating-star:hover span[aria-hidden="true"],
  .rating-star:hover ~ .rating-star span[aria-hidden="true"],
  .rating-star input:checked ~ span[aria-hidden="true"],
  .rating-star input:checked + span[aria-hidden="true"] {
    color: var(--terracotta, #c05b3e);
  }
  /* Selected + all following (which are earlier stars because flex-direction: row-reverse) */
  .rating-picker:hover .rating-star span[aria-hidden="true"] { color: rgba(46, 42, 38, 0.2); }
  .rating-picker .rating-star:hover span[aria-hidden="true"],
  .rating-picker .rating-star:hover ~ .rating-star span[aria-hidden="true"] { color: var(--terracotta, #c05b3e); }

  .review-field-consent label {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    cursor: pointer;
    color: var(--ink-900, #2e2a26);
    font-weight: normal;
  }
  .review-field-consent input[type="checkbox"] { margin-top: 0.25rem; }

  .review-turnstile { min-height: 65px; }

  .review-honeypot {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .review-honeypot input { width: 1px; }

  .review-submit-row { display: flex; justify-content: flex-end; }
  .review-form-status {
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
  }
  .review-form-status[data-tone="ok"] {
    background: rgba(76, 145, 65, 0.1);
    color: #2f5d24;
  }
  .review-form-status[data-tone="err"] {
    background: rgba(192, 91, 62, 0.12);
    color: #8a3820;
  }
  .review-form-disabled {
    text-align: center;
    padding: 1rem 0;
  }
  .review-form-disabled p { margin-bottom: 1rem; color: var(--ink-soft, #6b6560); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>

<script define:vars={{ errorsMap: t.errors, prefix: t.error_prefix, thanksTitle: t.thanks_title, thanksBody: t.thanks_body }}>
  // On page load, check ?review=thanks or ?review=error&reason=… and show
  // a status banner. The Function does a 303 back to /?review=…#testimonials
  // so this runs on the landing page after submission.
  (function () {
    const params = new URLSearchParams(window.location.search);
    const state = params.get('review');
    if (!state) return;

    const status = document.querySelector('[data-review-form-status]');
    if (!status) return;

    if (state === 'thanks') {
      status.hidden = false;
      status.dataset.tone = 'ok';
      status.innerHTML = `<strong>${thanksTitle}</strong> ${thanksBody}`;
    } else if (state === 'error') {
      const reason = params.get('reason') || 'bad_form';
      const msg = errorsMap[reason] || errorsMap.bad_form;
      status.hidden = false;
      status.dataset.tone = 'err';
      status.textContent = prefix + msg;
    }

    // Scroll to #testimonials so the banner is visible.
    const anchor = document.getElementById('testimonials');
    if (anchor) anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
  })();
</script>
