---
import fr from '../content/press.fr.json';
import en from '../content/press.en.json';

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? en : fr;
---
<section id="press" class="section">
  <div class="section-inner">
    <div class="card max-w-4xl mx-auto" data-reveal>
      <p class="eyebrow mb-3">
        <span class="breathing-dot"></span>
        <span>{t.eyebrow}</span>
      </p>
      <h2 class="font-serif text-2xl md:text-3xl leading-snug mb-2">{t.title}</h2>
      <p class="text-lg text-[color:var(--ink-soft)] italic mb-4">
        {t.subtitle}
      </p>
      <blockquote class="border-l-2 border-[color:var(--terracotta)] pl-4 text-[color:var(--ink)] leading-relaxed mb-5">
        « {t.quote} »
      </blockquote>
      <div class="flex flex-wrap items-center gap-4 justify-between pt-3 border-t border-[rgba(46,42,38,0.08)]">
        <span class="text-sm text-[color:var(--ink-soft)]">
          {t.date}
        </span>
        <a href={t.cta_href} target="_blank" rel="noopener" class="btn btn-ghost text-sm">
          {t.cta_label} →
        </a>
      </div>
    </div>
  </div>
</section>
