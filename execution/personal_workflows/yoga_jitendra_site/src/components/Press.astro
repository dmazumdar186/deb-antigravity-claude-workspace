---
import fr from '../content/press.fr.json';
import en from '../content/press.en.json';
---
<section id="press" class="section">
  <div class="section-inner">
    <div class="card max-w-4xl mx-auto" data-reveal>
      <p class="eyebrow mb-3">
        <span class="breathing-dot"></span>
        <span data-lang-content="fr">{fr.eyebrow}</span>
        <span data-lang-content="en">{en.eyebrow}</span>
      </p>
      <h2 class="font-serif text-2xl md:text-3xl leading-snug mb-2">{fr.title}</h2>
      <p class="text-lg text-[color:var(--ink-soft)] italic mb-4">
        <span data-lang-content="fr">{fr.subtitle}</span>
        <span data-lang-content="en">{en.subtitle}</span>
      </p>
      <blockquote class="border-l-2 border-[color:var(--terracotta)] pl-4 text-[color:var(--ink)] leading-relaxed mb-5">
        <span data-lang-content="fr">« {fr.quote} »</span>
        <span data-lang-content="en">« {en.quote} »</span>
      </blockquote>
      <div class="flex flex-wrap items-center gap-4 justify-between pt-3 border-t border-[rgba(46,42,38,0.08)]">
        <span class="text-sm text-[color:var(--ink-soft)]">
          <span data-lang-content="fr">{fr.date}</span>
          <span data-lang-content="en">{en.date}</span>
        </span>
        <a href={fr.cta_href} target="_blank" rel="noopener" class="btn btn-ghost text-sm">
          <span data-lang-content="fr">{fr.cta_label} →</span>
          <span data-lang-content="en">{en.cta_label} →</span>
        </a>
      </div>
    </div>
  </div>
</section>
