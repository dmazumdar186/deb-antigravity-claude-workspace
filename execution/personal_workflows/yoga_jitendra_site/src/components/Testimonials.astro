---
// Testimonials.astro — homepage social-proof section.
//
// Refactored to render from KV-backed reviews.json (via loadReviews())
// instead of the hardcoded recommendations.{fr,en}.json. Embeds the
// on-site review submission form directly below the grid — no navigation
// hop needed for a student to add their review.
//
// The full /reviews page is the "browse everything" surface; this section
// is the highlights + drop-off point for new submissions.

import { loadReviews } from '../lib/reviews.mjs';
import ReviewsGrid from './ReviewsGrid.astro';
import ReviewForm from './ReviewForm.astro';

const { lang = 'fr' } = Astro.props;

const { reviews, count, average_rating } = loadReviews();

// Homepage shows up to 6 by default; the "show more" toggle inside
// ReviewsGrid reveals the rest without a page change.
const t = lang === 'en'
  ? {
      prefix: 'What students say',
      reviews_word: (n: number) => `review${n === 1 ? '' : 's'}`,
      title: 'An attentive practice, held by tradition.',
      cta_full: 'See all reviews',
      cta_add: 'Add yours',
      review_page: '/en/reviews/',
    }
  : {
      prefix: "Ce qu'en disent les élèves",
      reviews_word: (_n: number) => 'avis',
      title: 'Une pratique attentive, tenue par la tradition.',
      cta_full: 'Voir tous les avis',
      cta_add: 'Ajouter le vôtre',
      review_page: '/reviews/',
    };
---

<section id="testimonials" class="section">
  <div class="section-inner">
    <header class="max-w-3xl mb-12">
      <p class="eyebrow mb-4" data-reveal>
        <span class="breathing-dot"></span>
        {/* Eyebrow is structured so the client-side augmentation script can
            update the count / avg spans in place when it injects fresh
            reviews from KV. Static template literals baked the numbers into
            unreachable text and blocked live updates. */}
        <span>{t.prefix} · <span data-live-review-count={String(count)}>{count}</span> <span data-live-reviews-word={t.reviews_word(count)}>{t.reviews_word(count)}</span>{average_rating ? (<> · <span data-live-review-avg={String(average_rating)}>{average_rating}</span>/5</>) : null}</span>
      </p>
      <h2 class="text-4xl md:text-5xl leading-[1.05]" data-reveal>
        <span>{t.title}</span>
      </h2>
    </header>

    <ReviewsGrid lang={lang} reviews={reviews} initial={6} />

    <div class="testimonials-cta">
      <a href={t.review_page} class="btn btn-ghost">{t.cta_full}</a>
      <a href={`${t.review_page}#add`} class="btn btn-primary">{t.cta_add}</a>
    </div>

    <div class="testimonials-form" id="add">
      <ReviewForm lang={lang} compact={true} />
    </div>
  </div>
</section>

<style>
  .testimonials-cta {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .testimonials-form {
    max-width: 720px;
    margin: 3rem auto 0;
  }
</style>
