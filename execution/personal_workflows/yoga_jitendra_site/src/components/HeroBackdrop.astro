---
---
<div class="hero-backdrop" aria-hidden="true">
  <svg
    class="mandala"
    viewBox="-300 -300 600 600"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Outer shimmer rings -->
    <g class="ring-outer">
      <circle cx="0" cy="0" r="270" fill="none" stroke="var(--sand, #D9C7A7)" stroke-width="0.75" />
      <circle cx="0" cy="0" r="255" fill="none" stroke="var(--sand, #D9C7A7)" stroke-width="0.5" stroke-dasharray="1 4" />
      <circle cx="0" cy="0" r="282" fill="none" stroke="var(--sand, #D9C7A7)" stroke-width="0.5" stroke-dasharray="0.5 6" />
    </g>

    <!-- Whole mandala rotation -->
    <g class="mandala-spin">
      <!-- Inner ring -->
      <circle cx="0" cy="0" r="92" fill="none" stroke="var(--sage, #6B7A5A)" stroke-width="0.6" opacity="0.18" />
      <circle cx="0" cy="0" r="78" fill="none" stroke="var(--sage, #6B7A5A)" stroke-width="0.4" opacity="0.16" stroke-dasharray="1 3" />

      <!-- 12 lotus petals -->
      <g class="petals">
        <g transform="rotate(0)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(30)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(60)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(90)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(120)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(150)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(180)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(210)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(240)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(270)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(300)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
        <g transform="rotate(330)"><path d="M 0 -78 C 24 -150, 24 -150, 0 -220 C -24 -150, -24 -150, 0 -78 Z" /></g>
      </g>

      <!-- 12 inner accent petals -->
      <g class="petals-inner">
        <g transform="rotate(15)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(45)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(75)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(105)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(135)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(165)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(195)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(225)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(255)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(285)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(315)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
        <g transform="rotate(345)"><path d="M 0 -78 C 14 -108, 14 -108, 0 -148 C -14 -108, -14 -108, 0 -78 Z" /></g>
      </g>

      <!-- Radial spokes -->
      <g class="spokes" stroke="var(--sand, #D9C7A7)" stroke-width="0.4" opacity="0.16">
        <line x1="0" y1="-92" x2="0" y2="-225" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(30)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(60)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(90)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(120)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(150)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(180)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(210)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(240)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(270)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(300)" />
        <line x1="0" y1="-92" x2="0" y2="-225" transform="rotate(330)" />
      </g>

      <!-- Central breath element -->
      <g class="mandala-center">
        <circle cx="0" cy="0" r="58" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.8" opacity="0.2" />
        <circle cx="0" cy="0" r="48" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.6" opacity="0.18" />
        <circle cx="0" cy="0" r="38" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.5" opacity="0.16" stroke-dasharray="1 2" />
        <circle cx="0" cy="0" r="28" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.4" opacity="0.14" />
        <circle cx="0" cy="0" r="14" fill="none" stroke="var(--sage, #6B7A5A)" stroke-width="0.5" opacity="0.2" />
      </g>
    </g>
  </svg>
</div>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-backdrop .mandala {
    width: min(95vmin, 820px);
    height: auto;
    position: absolute;
    top: 50%;
    right: -6vmin;
    transform: translateY(-50%);
    display: block;
    opacity: 1;
  }

  .hero-backdrop .petals path {
    fill: none;
    stroke: var(--terracotta, #C9744A);
    stroke-width: 1.1;
    opacity: 0.42;
  }

  .hero-backdrop .petals-inner path {
    fill: none;
    stroke: var(--sage, #6B7A5A);
    stroke-width: 0.85;
    opacity: 0.36;
  }

  .hero-backdrop .mandala circle {
    stroke-width: 1.1;
  }

  /* Center breath: 6s cycle between 0.94x and 1.06x */
  .hero-backdrop .mandala-center {
    transform-origin: center;
    transform-box: fill-box;
    animation: hero-backdrop-breath 6s ease-in-out infinite;
  }

  @keyframes hero-backdrop-breath {
    0%, 100% {
      transform: scale(0.94);
    }
    50% {
      transform: scale(1.06);
    }
  }

  /* Whole mandala rotation: 75s per full turn */
  .hero-backdrop .mandala-spin {
    transform-origin: center;
    transform-box: fill-box;
    animation: hero-backdrop-rotate 75s linear infinite;
  }

  @keyframes hero-backdrop-rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* Outer rings shimmer: 10s between 0.10 and 0.22 opacity */
  .hero-backdrop .ring-outer {
    animation: hero-backdrop-shimmer 10s ease-in-out infinite;
  }

  @keyframes hero-backdrop-shimmer {
    0%, 100% {
      opacity: 0.30;
    }
    50% {
      opacity: 0.55;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-backdrop .mandala-center,
    .hero-backdrop .mandala-spin,
    .hero-backdrop .ring-outer {
      animation: none;
    }

    .hero-backdrop .mandala-center {
      transform: none;
    }

    .hero-backdrop .mandala-spin {
      transform: none;
    }

    .hero-backdrop .ring-outer {
      opacity: 0.16;
    }
  }
</style>
