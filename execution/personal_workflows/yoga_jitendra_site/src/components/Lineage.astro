---
import fr from '../content/lineage.fr.json';
import en from '../content/lineage.en.json';

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? en : fr;
---
<section id="lineage" class="section lineage-section">
  <!-- Full-section yantra backdrop: giant Devanagari ॐ centered, ringed by
       24-petal lotus, Sri Yantra triangles, corner bija-mantras. Breathing
       (slow scale) instead of rotating — feels grounded, not spinning. -->
  <div class="lineage-yantra-bg" aria-hidden="true">
    <svg viewBox="-500 -500 1000 1000" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
      <g class="yantra-breath">
        <!-- Outer sacred rings -->
        <circle cx="0" cy="0" r="470" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.6" opacity="0.20"/>
        <circle cx="0" cy="0" r="450" fill="none" stroke="var(--sage, #6B7A5A)" stroke-width="0.4" opacity="0.18" stroke-dasharray="2 5"/>
        <circle cx="0" cy="0" r="360" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="0.7" opacity="0.22"/>

        <!-- 24-petal outer lotus (padma) -->
        {Array.from({ length: 24 }).map((_, i) => (
          <path
            d="M 0 -360 C 26 -290, 26 -290, 0 -220 C -26 -290, -26 -290, 0 -360 Z"
            fill="none"
            stroke="var(--terracotta, #C9744A)"
            stroke-width="0.9"
            opacity="0.22"
            transform={`rotate(${i * 15})`}
          />
        ))}

        <!-- Sri Yantra hint: two interlocking triangles (Shiva + Shakti) -->
        <g opacity="0.16">
          <polygon points="0,-200 173,100 -173,100" fill="none" stroke="var(--sage, #6B7A5A)" stroke-width="1.3"/>
          <polygon points="0,200 173,-100 -173,-100" fill="none" stroke="var(--terracotta, #C9744A)" stroke-width="1.3"/>
        </g>

        <!-- Inner 8-petal lotus (filled, softer) -->
        {[0, 45, 90, 135, 180, 225, 270, 315].map((deg) => (
          <path
            d="M 0 -150 C 22 -108, 22 -108, 0 -66 C -22 -108, -22 -108, 0 -150 Z"
            fill="var(--terracotta, #C9744A)"
            opacity="0.09"
            transform={`rotate(${deg})`}
          />
        ))}

        <!-- Bindu (center point) -->
        <circle cx="0" cy="0" r="5" fill="var(--terracotta, #C9744A)" opacity="0.5"/>
      </g>

      <!-- The huge centered ॐ -->
      <text
        x="0" y="90"
        text-anchor="middle"
        font-family="'Noto Serif Devanagari','Noto Sans Devanagari','Nirmala UI',serif"
        font-size="380"
        fill="var(--terracotta, #C9744A)"
        opacity="0.11"
      >ॐ</text>

      <!-- Corner bija-mantras: श्री · ह्रीं · सो · हं (Hamsa/Sohaṃ + Sri/Hrim) -->
      <text x="-390" y="-360" text-anchor="middle" font-family="'Noto Serif Devanagari','Noto Sans Devanagari','Nirmala UI',serif" font-size="52" fill="var(--sage, #6B7A5A)" opacity="0.28">श्री</text>
      <text x="390"  y="-360" text-anchor="middle" font-family="'Noto Serif Devanagari','Noto Sans Devanagari','Nirmala UI',serif" font-size="52" fill="var(--sage, #6B7A5A)" opacity="0.28">ह्रीं</text>
      <text x="-390" y="410"  text-anchor="middle" font-family="'Noto Serif Devanagari','Noto Sans Devanagari','Nirmala UI',serif" font-size="52" fill="var(--terracotta, #C9744A)" opacity="0.28">सो</text>
      <text x="390"  y="410"  text-anchor="middle" font-family="'Noto Serif Devanagari','Noto Sans Devanagari','Nirmala UI',serif" font-size="52" fill="var(--terracotta, #C9744A)" opacity="0.28">हं</text>
    </svg>
  </div>

  <div class="section-inner">
    <div class="lineage-grid">
      <div>
        <p class="eyebrow mb-4" data-reveal>
          <span class="breathing-dot"></span>
          <span>{t.eyebrow}</span>
        </p>
        <h2 class="text-4xl md:text-5xl leading-[1.05] mb-8" data-reveal>
          {t.title}
        </h2>

        {t.paragraphs_before.map((p) => (
          <p class="text-[17px] leading-relaxed text-[color:var(--ink)] max-w-prose2 mb-6" data-reveal>
            {p}
          </p>
        ))}

        <!-- SHLOKA — Sanskrit sūtra display -->
        <figure class="shloka" data-reveal>
          <div class="shloka-devanagari">{t.shloka.devanagari}</div>
          <div class="shloka-translit">{t.shloka.translit}</div>
          <blockquote class="shloka-translation">
            « {t.shloka.translation} »
          </blockquote>
          <figcaption class="shloka-source">{t.shloka.source}</figcaption>
        </figure>

        {t.paragraphs_after.map((p) => (
          <p class="text-[17px] leading-relaxed text-[color:var(--ink)] max-w-prose2 mb-6" data-reveal>
            {p}
          </p>
        ))}

        <!-- ASHTANGA — 8 limbs as pill-list -->
        <div class="mt-10" data-reveal>
          <p class="eyebrow mb-4">
            {t.ashtanga_label}
          </p>
          <ol class="ashtanga-list">
            {t.ashtanga.map((limb, i) => (
              <li>
                <span class="ashtanga-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="ashtanga-sanskrit">{limb.sanskrit}</span>
                <span class="ashtanga-gloss">{limb.gloss}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lineage-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(700px 400px at 10% 40%, rgba(107, 122, 90, 0.10), transparent 60%),
      radial-gradient(500px 300px at 100% 90%, rgba(201, 116, 74, 0.08), transparent 60%);
  }
  .lineage-yantra-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
  }
  .lineage-yantra-bg svg {
    width: min(115%, 1400px);
    height: auto;
    max-height: 130%;
    display: block;
    transform-origin: center;
    animation: yantra-breath 14s ease-in-out infinite;
  }
  @keyframes yantra-breath {
    0%, 100% { transform: scale(1);     opacity: 1;    }
    50%      { transform: scale(1.035); opacity: 0.93; }
  }
  @media (prefers-reduced-motion: reduce) {
    .lineage-yantra-bg svg { animation: none; }
  }
  @media (max-width: 768px) {
    .lineage-yantra-bg svg { width: 160%; max-height: 105%; }
  }

  .lineage-grid {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin-inline: auto;
  }

  /* Sanskrit sutra display */
  .shloka {
    position: relative;
    margin: 2.5rem 0;
    padding: 2.5rem 2rem;
    border-radius: 1.5rem;
    background: linear-gradient(180deg, rgba(251, 247, 238, 0.85), rgba(251, 247, 238, 0.55));
    border: 1px solid rgba(201, 116, 74, 0.16);
    box-shadow: 0 20px 60px -32px rgba(46, 42, 38, 0.25);
    text-align: center;
  }
  .shloka::before, .shloka::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 116, 74, 0.5), transparent);
  }
  .shloka::before { top: 1.1rem; }
  .shloka::after  { bottom: 1.1rem; }
  .shloka-devanagari {
    font-family: 'Noto Serif Devanagari', 'Noto Sans Devanagari', 'Fraunces', serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--ink);
    letter-spacing: 0;
    margin-bottom: 1rem;
    line-height: 1.35;
  }
  .shloka-translit {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--terracotta);
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }
  .shloka-translation {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--ink);
    max-width: 44ch;
    margin: 0 auto 0.75rem;
  }
  .shloka-source {
    font-size: 0.85rem;
    color: var(--ink-soft);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Ashtanga eight-limb list */
  .ashtanga-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: none;
  }
  .ashtanga-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 1rem;
    align-items: baseline;
    padding: 0.75rem 0;
    border-top: 1px solid rgba(46, 42, 38, 0.08);
  }
  .ashtanga-num {
    grid-row: span 2;
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    color: var(--terracotta);
    line-height: 1;
  }
  .ashtanga-sanskrit {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    color: var(--ink);
    line-height: 1.2;
  }
  .ashtanga-gloss {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.35;
    grid-column: 2;
  }
</style>
