---
import fr from '../content/schedule.fr.json';
import en from '../content/schedule.en.json';

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? en : fr;
---
<section id="schedule" class="section" style="background: linear-gradient(180deg, transparent, rgba(217, 199, 167, 0.15) 40%, transparent);">
  <div class="section-inner">
    <header class="max-w-3xl mb-10">
      <p class="eyebrow mb-4" data-reveal>
        <span class="breathing-dot"></span>
        <span>{t.eyebrow}</span>
      </p>
      <h2 class="text-4xl md:text-5xl mb-2" data-reveal>
        <span>{t.title}</span>
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <div class="md:col-span-5" data-reveal>
        <div class="card">
          <p class="eyebrow mb-2">
            <span>{t.location_label}</span>
          </p>
          <div class="font-serif text-2xl leading-snug text-ink-900 mb-1">{t.location_line1}</div>
          <div class="text-[color:var(--ink-soft)] mb-4">{t.location_line2}</div>
          <a href={t.map_link} target="_blank" rel="noopener" class="text-sm text-[color:var(--terracotta)] hover:underline">
            <span>{t.map_link_label} →</span>
          </a>
        </div>

        <ul class="mt-5 space-y-4 text-[15px] leading-relaxed text-[color:var(--ink-soft)]">
          {t.notes.map((n) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--terracotta)]"></span>
              <span>
                <span>{n}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-7" data-reveal>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {t.gallery.map((g) => (
            <div class="frame aspect-[3/4]">
              <img src={g.src} alt={g.alt}
                   width="900" height="1200" loading="lazy" decoding="async"
                   class="w-full h-full object-cover" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
