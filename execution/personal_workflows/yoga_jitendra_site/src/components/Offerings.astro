---
import fr from '../content/offerings.fr.json';
import en from '../content/offerings.en.json';
---
<section id="offerings" class="section">
  <div class="section-inner">
    <header class="max-w-3xl mb-12">
      <p class="eyebrow mb-4" data-reveal>
        <span class="breathing-dot"></span>
        <span data-lang-content="fr">{fr.eyebrow}</span>
        <span data-lang-content="en">{en.eyebrow}</span>
      </p>
      <h2 class="text-4xl md:text-5xl mb-4" data-reveal>
        <span data-lang-content="fr">{fr.title}</span>
        <span data-lang-content="en">{en.title}</span>
      </h2>
      <p class="text-lg text-[color:var(--ink-soft)]" data-reveal>
        <span data-lang-content="fr">{fr.subtitle}</span>
        <span data-lang-content="en">{en.subtitle}</span>
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
      {fr.tiles.map((t, i) => (
        <article class="card flex flex-col overflow-hidden" data-reveal>
          <div class="relative aspect-[4/3] -m-6 mb-4 overflow-hidden rounded-t-[1.25rem]">
            <img src={t.image} alt={t.image_alt}
                 width="800" height="600" loading="lazy" decoding="async"
                 class="w-full h-full object-cover" />
          </div>
          <p class="eyebrow mb-2">
            <span data-lang-content="fr">{t.kicker}</span>
            <span data-lang-content="en">{en.tiles[i].kicker}</span>
          </p>
          <h3 class="font-serif text-xl mb-2 text-ink-900 leading-snug">
            <span data-lang-content="fr">{t.title}</span>
            <span data-lang-content="en">{en.tiles[i].title}</span>
          </h3>
          <p class="text-[15px] text-[color:var(--ink-soft)] leading-relaxed mb-4">
            <span data-lang-content="fr">{t.blurb}</span>
            <span data-lang-content="en">{en.tiles[i].blurb}</span>
          </p>
          <p class="mt-auto pt-3 border-t border-[rgba(46,42,38,0.08)] text-sm font-medium text-[color:var(--terracotta)]">
            <span data-lang-content="fr">{t.meta}</span>
            <span data-lang-content="en">{en.tiles[i].meta}</span>
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
