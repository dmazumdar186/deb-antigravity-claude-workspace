---
import fr from '../content/i18n_ui.fr.json';
import en from '../content/i18n_ui.en.json';
const year = new Date().getFullYear();
---
<footer class="section" style="padding-top: 3rem; padding-bottom: 3rem;">
  <div class="section-inner border-t border-[rgba(46,42,38,0.10)] pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-5 text-sm text-[color:var(--ink-soft)]">
    <div class="flex items-center gap-3">
      <span class="inline-block w-2 h-2 rounded-full bg-[color:var(--terracotta)] breathing-dot" style="margin:0"></span>
      <div>
        <div class="font-serif text-base text-ink-900">Yoga avec Jitendra</div>
        <div class="text-xs">
          <span data-lang-content="fr">{fr.footer_tagline}</span>
          <span data-lang-content="en">{en.footer_tagline}</span>
          · © {year}
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs">
      <span class="text-[color:var(--ink-soft)]/70 uppercase tracking-wider">
        <span data-lang-content="fr">{fr.socials_label}</span>
        <span data-lang-content="en">{en.socials_label}</span>
      </span>
      {fr.socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" class="hover:text-[color:var(--terracotta)]">{s.label}</a>
      ))}
    </div>
  </div>

  <div class="section-inner mt-6 pt-4 border-t border-[rgba(46,42,38,0.06)] text-center text-xs text-[color:var(--ink-soft)]/70">
    <span data-lang-content="fr">Conçu par Debanjan · </span>
    <span data-lang-content="en">Designed by Debanjan · </span>
    <a
      href="https://prodcraft.fyi"
      target="_blank"
      rel="noopener"
      class="text-[color:var(--terracotta)] hover:underline"
    >ProdCraft</a>
  </div>
</footer>
