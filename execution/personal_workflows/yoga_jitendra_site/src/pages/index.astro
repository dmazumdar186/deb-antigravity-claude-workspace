---
import Base       from '../layouts/Base.astro';
import TopNav     from '../components/TopNav.astro';
import Hero       from '../components/Hero.astro';
import About      from '../components/About.astro';
import Lineage    from '../components/Lineage.astro';
import Offerings  from '../components/Offerings.astro';
import Schedule   from '../components/Schedule.astro';
import Testimonials from '../components/Testimonials.astro';
import Press      from '../components/Press.astro';
import Contact    from '../components/Contact.astro';
import Footer     from '../components/Footer.astro';
import AmbientAudio from '../components/AmbientAudio.astro';

const lang = 'fr';
---
<Base
  title="Hatha Yoga traditionnel indien à Paris — Yoga avec Jitendra"
  lang={lang}
>
  <TopNav lang={lang} />
  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Lineage lang={lang} />
    <Offerings lang={lang} />
    <Schedule lang={lang} />
    <Testimonials lang={lang} />
    <Press lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
  <AmbientAudio lang={lang} />
</Base>
