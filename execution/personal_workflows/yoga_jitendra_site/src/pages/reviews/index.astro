---
// /reviews/ — full reviews listing page (French default).
//
// Renders every approved review with the submission form directly on
// the page. Linked from the Testimonials section on the homepage via
// "Voir tous les avis". Anchors to #add for the "Ajouter le vôtre" CTA.

import Base from '../../layouts/Base.astro';
import TopNav from '../../components/TopNav.astro';
import Footer from '../../components/Footer.astro';
import ReviewsGrid from '../../components/ReviewsGrid.astro';
import ReviewForm from '../../components/ReviewForm.astro';
import { loadReviews } from '../../lib/reviews.mjs';

const lang = 'fr';
const { reviews, count, average_rating } = loadReviews();
---
<Base
  title="Tous les avis · Yoga avec Jitendra"
  description="Tous les avis d'élèves de Jitendra Kumar, professeur de Hatha Yoga à Paris (Passy · Paris 16). Superprof, Meetup, TrainMe, Instagram, avis directs."
  lang={lang}
  pathFr="/reviews/"
  pathEn="/en/reviews/"
>
  <TopNav lang={lang} />
  <main>
    <section class="section">
      <div class="section-inner">
        <header class="max-w-3xl mb-8">
          <p class="eyebrow mb-4" data-reveal>
            <span class="breathing-dot"></span>
            {/* Structured so client-side augmentation can live-update the
                count and avg when it injects fresh KV reviews. */}
            <span>Tous les avis · <span data-live-review-count={String(count)}>{count}</span> <span data-live-reviews-word="avis">avis</span>{average_rating ? (<> · <span data-live-review-avg={String(average_rating)}>{average_rating}</span>/5</>) : null}</span>
          </p>
          <h1 class="text-4xl md:text-5xl leading-[1.05]" data-reveal>
            <span>Ce que les élèves disent — de partout.</span>
          </h1>
          <p class="reviews-lede" data-reveal>
            Superprof, Meetup, TrainMe, Instagram, courriels privés, avis directs sur ce site — tous rassemblés ici, dans un seul endroit.
          </p>
        </header>

        <ReviewsGrid lang={lang} reviews={reviews} initial={12} />

        <div id="add" class="reviews-form-block">
          <ReviewForm lang={lang} compact={false} />
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Base>

<style>
  .reviews-lede {
    color: var(--ink-soft, #6b6560);
    max-width: 60ch;
    line-height: 1.55;
    margin: 1rem 0 0;
    font-size: 1.05rem;
  }
  .reviews-form-block {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(46, 42, 38, 0.08);
  }
</style>
